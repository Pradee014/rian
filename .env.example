# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_RIAN_ENV=local

# Feature flags
NEXT_PUBLIC_USE_MOCK_PROVIDERS=true
NEXT_PUBLIC_ENABLE_LOCAL_MIC_CAPTURE=true
NEXT_PUBLIC_ENABLE_TRACE_PREVIEW=true

# LiveKit voice room
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Supabase database and storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUDIO_BUCKET=rian-audio

# STT providers
STT_PROVIDER=mock
GROQ_API_KEY=
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# xAI realtime voice
XAI_API_KEY= 
XAI_REALTIME_ENDPOINT=wss://api.x.ai/v1/realtime
XAI_REALTIME_MODEL=grok-voice-think-fast-1.0
XAI_RIA_VOICE=ara
XAI_IAN_VOICE=rex

# LLM providers
LIVE_LLM_PROVIDER=mock
REVIEW_LLM_PROVIDER=mock
XAI_TEXT_MODEL=
GROQ_LLM_MODEL=
OPENAI_LIVE_MODEL=
OPENAI_REVIEW_MODEL=

# TTS providers
TTS_PROVIDER=mock
XAI_TTS_MODEL=
OPENAI_TTS_MODEL=
OPENAI_TTS_RIA_VOICE=
OPENAI_TTS_IAN_VOICE=
ELEVENLABS_API_KEY=
ELEVENLABS_RIA_VOICE_ID=
ELEVENLABS_IAN_VOICE_ID=
CARTESIA_API_KEY=
CARTESIA_RIA_VOICE_ID=
CARTESIA_IAN_VOICE_ID=

# Local development
LOG_LEVEL=debug
TRACE_SAMPLE_RATE=1
